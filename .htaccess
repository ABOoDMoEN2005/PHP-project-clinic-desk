# =============================================================
# ملف .htaccess - توجيه كل الطلبات لـ index.php
#
# هاد الملف بيقول لـ Apache:
# كل طلب جاي للموقع، وجّهه لـ index.php
# إلا إذا كان الملف موجود فعلياً (زي الصور والـ CSS)
# =============================================================

Options -Indexes

RewriteEngine On

# إذا الملف موجود فعلاً على السيرفر، خليه يشتغل عادي
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# غير كذلك، وجّه كل شي لـ index.php
RewriteRule ^ index.php [L]
